{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aascribe://shapes/FileDescription",
  "title": "FileDescription",
  "description": "Summary payload for aascribe describe.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "path": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "length": {
      "type": "string",
      "enum": ["short", "medium", "long"]
    },
    "focus": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["path", "summary", "length"]
}
