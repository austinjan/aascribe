{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aascribe://shapes/OperationEventList",
  "title": "OperationEventList",
  "description": "Event-history payload for a long-running aascribe operation.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "operation_id": {
      "type": "string"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "time": {
            "type": "string",
            "format": "date-time"
          },
          "level": {
            "type": "string",
            "enum": ["debug", "info", "warn", "error"]
          },
          "stage": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        },
        "required": ["time", "level", "stage", "message", "data"]
      }
    }
  },
  "required": ["operation_id", "events"]
}
