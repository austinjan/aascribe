{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aascribe://shapes/ConsolidationResult",
  "title": "ConsolidationResult",
  "description": "Result payload for aascribe consolidate.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "created": {
      "type": "array",
      "items": {
        "$ref": "ConsolidatedMemory.schema.json"
      }
    },
    "consumed": {
      "type": "integer",
      "minimum": 0
    },
    "skipped": {
      "type": "integer",
      "minimum": 0
    }
  },
  "required": ["created", "consumed", "skipped"]
}
