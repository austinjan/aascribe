{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aascribe://shapes/OperationStatus",
  "title": "OperationStatus",
  "description": "Current lifecycle and progress snapshot for a long-running aascribe operation.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "operation_id": {
      "type": "string"
    },
    "command": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": ["pending", "running", "succeeded", "failed", "canceled"]
    },
    "stage": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "current": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "unit": {
          "type": "string"
        },
        "percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      },
      "required": ["current", "total", "unit", "percent"]
    },
    "result_ready": {
      "type": "boolean"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "required": ["code", "message"]
    }
  },
  "required": [
    "operation_id",
    "command",
    "state",
    "stage",
    "message",
    "started_at",
    "updated_at",
    "result_ready"
  ]
}
