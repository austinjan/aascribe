{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aascribe://shapes/MemoryEntryDetail",
  "title": "MemoryEntryDetail",
  "description": "Full single-memory payload for aascribe show.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "tier": {
      "type": "string",
      "enum": ["short", "long"]
    },
    "content": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source": {
      "type": "string"
    },
    "session": {
      "type": "string"
    },
    "importance": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["id", "tier", "content", "created_at"]
}
