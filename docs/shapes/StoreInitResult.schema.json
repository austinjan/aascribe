{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aascribe://shapes/StoreInitResult",
  "title": "StoreInitResult",
  "description": "Result payload for aascribe init.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "store": {
      "type": "string",
      "description": "Resolved absolute or user-supplied store path."
    },
    "created": {
      "type": "boolean",
      "description": "True when a new store was created."
    },
    "reinitialized": {
      "type": "boolean",
      "description": "True when an existing store was recreated with --force."
    },
    "layout_version": {
      "type": "string",
      "description": "Bootstrap store layout version identifier."
    },
    "config_path": {
      "type": "string",
      "description": "Path to the config.toml file in the sibling config directory."
    },
    "config_created": {
      "type": "boolean",
      "description": "True when init created the default config.toml template."
    }
  },
  "required": ["store", "created", "reinitialized", "config_path", "config_created"],
  "examples": [
    {
      "store": "/path/to/project/data/memory",
      "created": true,
      "reinitialized": false,
      "layout_version": "bootstrap-v1",
      "config_path": "/path/to/project/data/config/config.toml",
      "config_created": true
    }
  ]
}
